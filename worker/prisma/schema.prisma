// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WarmupStatus {
  COLD
  WARMING
  WARMED
  PAUSED
}

enum MailboxFolderKind {
  INBOX
  SPAM
  SENT
  ARCHIVE
  OTHER
}

enum CampaignChannel {
  EMAIL
  WHATSAPP
}

enum WhatsAppConnectionStatus {
  DISCONNECTED
  QR_PENDING
  CONNECTED
  ERROR
}

enum ApiDispatchChannel {
  EMAIL
  WHATSAPP
}

enum ApiDispatchStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  REJECTED_NO_CAPACITY
}

model MailAccount {
  id           String   @id @default(cuid())
  type         String   // "zoho" | "gmail"
  email        String   @unique
  displayName  String
  // Zoho SMTP fields
  smtpHost     String?
  smtpPort     Int?
  smtpPassword String?  // AES-256 encrypted
  // Gmail OAuth fields
  accessToken  String?  // AES-256 encrypted
  refreshToken String?
  tokenExpiry  DateTime?
  // Zoho OAuth / Mail API fields
  zohoAccountId     String?
  zohoRegion        String?
  zohoAccessToken   String?  @db.Text
  zohoRefreshToken  String?  @db.Text
  zohoTokenExpiry   DateTime?
  zohoMailboxMode   String   @default("imap") // imap|api
  zohoLastTokenRefreshAt DateTime?
  zohoAuthError     String?  @db.Text
  // Inbox sync / mailbox interaction fields
  imapHost     String?
  imapPort     Int?
  imapSecure   Boolean  @default(true)
  mailboxLastSyncedAt DateTime?
  mailboxSyncStatus   String   @default("idle") // idle|syncing|error
  mailboxSyncError    String?  @db.Text
  mailboxHealthScore  Int      @default(0)
  mailboxHealthStatus String   @default("cold") // cold|warming|healthy|at_risk|paused
  // Limits
  dailyLimit   Int      @default(40)
  sentToday    Int      @default(0)
  lastResetAt  DateTime @default(now())
  lastMailSentAt DateTime?
  apiReservationKey String?
  apiReservedUntil DateTime?
  isActive     Boolean  @default(true)
  warmupStatus WarmupStatus @default(COLD)
  warmupStage  Int      @default(0)
  warmupStartedAt DateTime?
  warmupCompletedAt DateTime?
  warmupPausedAt DateTime?
  recommendedDailyLimit Int @default(5)
  warmupAutoEnabled Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMails SentMail[]
  campaigns CampaignMailAccount[]
  warmupRecipients WarmupRecipient[] @relation("RecipientMailbox")
  warmupSends WarmupMailLog[] @relation("SenderMailbox")
  warmupReceived WarmupMailLog[] @relation("RecipientMailboxSends")
  mailboxThreads MailboxThread[]
  mailboxMessages MailboxMessage[]
  warmupHealthSnapshots WarmupHealthSnapshot[]
  complaintEvents ComplaintEvent[]
  apiDispatchRequests ApiDispatchRequest[] @relation("SelectedMailAccount")
}

model CsvFile {
  id           String    @id @default(cuid())
  originalName String
  storagePath  String
  rowCount     Int
  columnMap    Json      // { name: "col_A", website: "col_C", email: "col_F", ... }
  uploadedAt   DateTime  @default(now())

  rows      CsvRow[]
  campaigns Campaign[]
}

model CsvRow {
  id            String  @id @default(cuid())
  csvFileId     String
  rowIndex      Int
  rawData       Json    // original row data
  name          String?
  website       String?
  email         String?
  whatsapp      String?
  scrapedEmail  String?
  scrapedPhone  String?
  scrapeStatus  String  @default("pending") // pending|running|done|failed
  createdAt     DateTime @default(now())

  csvFile   CsvFile    @relation(fields: [csvFileId], references: [id], onDelete: Cascade)
  sentMails SentMail[]
  sentWhatsAppMessages SentWhatsAppMessage[]

  @@index([csvFileId])
  @@index([scrapeStatus])
}

model Campaign {
  id                  String   @id @default(cuid())
  name                String
  type                String   // "indian" | "international"
  channel             CampaignChannel @default(EMAIL)
  status              String   @default("draft") // draft|active|paused|completed
  guardrailReason     String?  @db.Text
  csvFileId           String
  prompt              String   @db.Text
  whatsappColumn      String?
  scrapeEmail         Boolean  @default(false)
  scrapeWhatsapp      Boolean  @default(false)
  dailyMailsPerAccount Int     @default(40)
  currentRowIndex     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  csvFile      CsvFile               @relation(fields: [csvFileId], references: [id])
  mailAccounts CampaignMailAccount[]
  whatsappAccounts CampaignWhatsAppAccount[]
  sentMails    SentMail[]
  sentWhatsAppMessages SentWhatsAppMessage[]
  complaintEvents ComplaintEvent[]

  @@index([status])
}

model CampaignMailAccount {
  campaignId    String
  mailAccountId String
  sentCount     Int    @default(0)
  lastSentAt    DateTime?

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mailAccount MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)

  @@id([campaignId, mailAccountId])
}

model WhatsAppAccount {
  id                 String   @id @default(cuid())
  displayName        String
  phoneNumber        String?
  isActive           Boolean  @default(true)
  connectionStatus   WhatsAppConnectionStatus @default(DISCONNECTED)
  sessionKey         String   @unique
  lastQr             String?  @db.Text
  lastConnectedAt    DateTime?
  lastError          String?
  dailyLimit         Int      @default(40)
  sentToday          Int      @default(0)
  lastResetAt        DateTime @default(now())
  lastMessageSentAt  DateTime?
  apiReservationKey  String?
  apiReservedUntil   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  campaigns          CampaignWhatsAppAccount[]
  sentMessages       SentWhatsAppMessage[]
  conversations      WhatsAppConversation[]
  conversationMessages WhatsAppConversationMessage[]
  apiDispatchRequests ApiDispatchRequest[] @relation("SelectedWhatsAppAccount")

  @@index([connectionStatus])
  @@index([isActive])
}

model CampaignWhatsAppAccount {
  campaignId       String
  whatsappAccountId String
  sentCount        Int      @default(0)
  lastSentAt       DateTime?

  campaign         Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  whatsappAccount  WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@id([campaignId, whatsappAccountId])
}

model SentWhatsAppMessage {
  id               String   @id @default(cuid())
  campaignId       String?
  csvRowId         String?
  whatsappAccountId String
  providerMessageId String?
  apiDispatchRequestId String? @unique
  toPhone          String
  message          String   @db.Text
  status           String   // "sent" | "failed"
  sentAt           DateTime @default(now())
  errorMessage     String?

  campaign         Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  csvRow           CsvRow?         @relation(fields: [csvRowId], references: [id], onDelete: SetNull)
  whatsappAccount  WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  apiDispatchRequest ApiDispatchRequest? @relation(fields: [apiDispatchRequestId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([whatsappAccountId])
  @@index([providerMessageId])
  @@index([apiDispatchRequestId])
  @@index([sentAt])
}

model WhatsAppConversation {
  id               String   @id @default(cuid())
  whatsappAccountId String
  participantJid   String
  participantPhone String?
  participantName  String?
  isManaged        Boolean  @default(true)
  lastMessageAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  whatsappAccount WhatsAppAccount              @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  messages        WhatsAppConversationMessage[]

  @@unique([whatsappAccountId, participantJid])
  @@index([whatsappAccountId, lastMessageAt])
}

model WhatsAppConversationMessage {
  id               String   @id @default(cuid())
  conversationId   String
  whatsappAccountId String
  providerMessageId String?
  direction        String   // inbound|outbound
  body             String   @db.Text
  status           String?
  sentAt           DateTime?
  receivedAt       DateTime?
  metadata         Json?
  createdAt        DateTime @default(now())

  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsAppAccount      @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@unique([whatsappAccountId, providerMessageId])
  @@index([conversationId, createdAt])
  @@index([whatsappAccountId, createdAt])
}

model SentMail {
  id            String   @id @default(cuid())
  campaignId    String?
  csvRowId      String?
  mailAccountId String
  apiDispatchRequestId String? @unique
  toEmail       String
  subject       String
  body          String   @db.Text
  status        String   // "sent" | "failed" | "bounced"
  sentAt        DateTime @default(now())
  errorMessage  String?

  campaign    Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  csvRow      CsvRow?     @relation(fields: [csvRowId], references: [id], onDelete: SetNull)
  mailAccount MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  apiDispatchRequest ApiDispatchRequest? @relation(fields: [apiDispatchRequestId], references: [id], onDelete: SetNull)
  complaintEvents ComplaintEvent[]

  @@index([campaignId])
  @@index([mailAccountId])
  @@index([apiDispatchRequestId])
  @@index([sentAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyPrefix   String
  keyHash     String   @unique
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  apiDispatchRequests ApiDispatchRequest[]

  @@index([isActive, createdAt])
}

model ApiDispatchRequest {
  id                    String            @id @default(cuid())
  channel               ApiDispatchChannel
  status                ApiDispatchStatus @default(QUEUED)
  requestedTo           String
  subject               String?
  content               String            @db.Text
  metadata              Json?
  apiKeyId              String
  idempotencyKey        String?
  selectedMailAccountId String?
  selectedWhatsAppAccountId String?
  errorMessage          String?           @db.Text
  providerMessageId     String?
  queuedAt              DateTime?
  processedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  apiKey            ApiKey           @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  selectedMailAccount MailAccount?   @relation("SelectedMailAccount", fields: [selectedMailAccountId], references: [id], onDelete: SetNull)
  selectedWhatsAppAccount WhatsAppAccount? @relation("SelectedWhatsAppAccount", fields: [selectedWhatsAppAccountId], references: [id], onDelete: SetNull)
  sentMail          SentMail?
  sentWhatsAppMessage SentWhatsAppMessage?

  @@index([channel, status, createdAt])
  @@index([apiKeyId, createdAt])
  @@unique([apiKeyId, idempotencyKey])
  @@index([selectedMailAccountId, createdAt])
  @@index([selectedWhatsAppAccountId, createdAt])
}

model UnsubscribeList {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model ComplaintEvent {
  id            String   @id @default(cuid())
  sentMailId    String?
  campaignId    String?
  mailAccountId String?
  email         String
  reason        String
  source        String   @default("manual")
  createdAt     DateTime @default(now())

  sentMail    SentMail?    @relation(fields: [sentMailId], references: [id], onDelete: SetNull)
  campaign    Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  mailAccount MailAccount? @relation(fields: [mailAccountId], references: [id], onDelete: SetNull)

  @@unique([sentMailId, reason, source])
  @@index([email, createdAt])
  @@index([mailAccountId, createdAt])
  @@index([campaignId, createdAt])
}

model WarmupRecipient {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false)
  mailAccountId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mailAccount MailAccount? @relation("RecipientMailbox", fields: [mailAccountId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([isSystem])
}

model WarmupMailLog {
  id                    String   @id @default(cuid())
  senderMailAccountId   String
  recipientEmail        String
  recipientType         String   // "system" | "external"
  recipientMailAccountId String?
  direction             String   // "outbound" | "reply"
  subject               String
  body                  String   @db.Text
  status                String   // "sent" | "failed" | "bounced"
  stage                 Int      @default(0)
  sentAt                DateTime @default(now())
  errorMessage          String?

  senderMailAccount   MailAccount  @relation("SenderMailbox", fields: [senderMailAccountId], references: [id], onDelete: Cascade)
  recipientMailAccount MailAccount? @relation("RecipientMailboxSends", fields: [recipientMailAccountId], references: [id], onDelete: SetNull)

  @@index([senderMailAccountId, sentAt])
  @@index([recipientMailAccountId, sentAt])
  @@index([status, sentAt])
}

model MailboxThread {
  id               String   @id @default(cuid())
  mailAccountId    String
  providerThreadId String
  subject          String?
  lastMessageAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mailAccount MailAccount      @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  messages    MailboxMessage[]

  @@unique([mailAccountId, providerThreadId])
  @@index([mailAccountId, lastMessageAt])
}

model MailboxMessage {
  id                String            @id @default(cuid())
  mailAccountId     String
  mailboxThreadId   String?
  providerMessageId String
  providerThreadId  String?
  folderKind        MailboxFolderKind @default(OTHER)
  folderName        String?
  direction         String            // inbound|outbound
  fromEmail         String?
  toEmail           String?
  subject           String?
  snippet           String?           @db.Text
  sentAt            DateTime?
  receivedAt        DateTime?
  messageIdHeader   String?
  inReplyToHeader   String?
  referencesHeader  String?           @db.Text
  isWarmup          Boolean           @default(false)
  isRead            Boolean           @default(false)
  isStarred         Boolean           @default(false)
  isSpam            Boolean           @default(false)
  openedAt          DateTime?
  repliedAt         DateTime?
  rescuedAt         DateTime?
  analysisStatus    String            @default("idle") // idle|pending|complete|error
  analysisRequestedAt DateTime?
  analyzedAt        DateTime?
  analysisModel     String?
  analysisLabel     String?
  analysisShouldReply Boolean?
  analysisPriority  String?
  analysisSummary   String?           @db.Text
  analysisReason    String?           @db.Text
  analysisError     String?           @db.Text
  analysisRaw       Json?
  metadata          Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  mailAccount   MailAccount    @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
  mailboxThread MailboxThread? @relation(fields: [mailboxThreadId], references: [id], onDelete: SetNull)

  @@unique([mailAccountId, providerMessageId])
  @@index([mailAccountId, receivedAt])
  @@index([mailAccountId, folderKind, receivedAt])
  @@index([mailAccountId, isWarmup, receivedAt])
  @@index([openedAt, analysisStatus, receivedAt])
  @@index([analysisLabel, analysisPriority, analyzedAt])
}

model WarmupHealthSnapshot {
  id            String   @id @default(cuid())
  mailAccountId String
  periodStart   DateTime
  periodEnd     DateTime
  healthScore   Int
  healthStatus  String   // cold|warming|healthy|at_risk|paused
  inboxRate     Float    @default(0)
  spamRate      Float    @default(0)
  readRate      Float    @default(0)
  replyRate     Float    @default(0)
  rescueRate    Float    @default(0)
  sentCount     Int      @default(0)
  receivedCount Int      @default(0)
  rescuedCount  Int      @default(0)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  mailAccount MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)

  @@index([mailAccountId, periodEnd])
}

model DomainHealthSnapshot {
  id                  String   @id @default(cuid())
  domain              String
  providerHint        String
  periodStart         DateTime
  periodEnd           DateTime
  mailboxCount        Int      @default(0)
  healthyCount        Int      @default(0)
  warmingCount        Int      @default(0)
  atRiskCount         Int      @default(0)
  pausedCount         Int      @default(0)
  averageHealthScore  Int      @default(0)
  activeCampaignCount Int      @default(0)
  sentCount7d         Int      @default(0)
  failedCount7d       Int      @default(0)
  bouncedCount7d      Int      @default(0)
  bounceRate7d        Float    @default(0)
  failureRate7d       Float    @default(0)
  complaintCount14d   Int      @default(0)
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  @@unique([domain, providerHint, periodStart, periodEnd])
  @@index([domain, providerHint, periodEnd])
}

// ─── NextAuth required models ───

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token                  String? @db.Text
  session_state             String?
  refresh_token_expires_in  Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
