# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/outreachos

# Redis
REDIS_URL=redis://localhost:6379

# Google (Gmail OAuth + Gemini)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# Zoho Mail OAuth / API
ZOHO_CLIENT_ID=your_zoho_client_id_here
ZOHO_CLIENT_SECRET=your_zoho_client_secret_here
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.in
ZOHO_MAIL_API_BASE_URL=https://mail.zoho.in/api
ZOHO_MAIL_OAUTH_SCOPE=ZohoMail.accounts.READ,ZohoMail.folders.READ,ZohoMail.messages.ALL

# AES-256 Encryption (exactly 32 characters)
ENCRYPTION_KEY=change-this-32-char-secret-key!!

# Scraper Microservice
SCRAPER_SERVICE_URL=http://localhost:8000
PUBLIC_URL=https://app.example.com

# Worker balancing
WORKER_GLOBAL_ACTIVE_LIMIT=4
WORKER_SWEEP_INTERVAL_MS=5000
WORKER_IDLE_CLOSE_MS=120000
CAMPAIGN_WORKER_CONCURRENCY=1
MAIL_WORKER_CONCURRENCY=1
SCRAPE_WORKER_CONCURRENCY=1
WHATSAPP_WORKER_CONCURRENCY=1
WARMUP_WORKER_CONCURRENCY=1
WHATSAPP_SESSION_WORKER_CONCURRENCY=1
WHATSAPP_SESSION_KEEPALIVE=false
REPLY_ANALYSIS_BASE_URL=http://127.0.0.1:8091
REPLY_ANALYSIS_MODEL=gemma-2-2b-it
REPLY_ANALYSIS_TIMEOUT_MS=30000
REPLY_ANALYSIS_MAX_TOKENS=220
REPLY_ANALYSIS_WORKER_CONCURRENCY=1

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
